{
  "version": 2,
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/index.js": { "runtime": "vercel-node@latest" }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}