{
  "version": 2,
  "installCommand": "npm run install-all",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/index.js" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/index.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}